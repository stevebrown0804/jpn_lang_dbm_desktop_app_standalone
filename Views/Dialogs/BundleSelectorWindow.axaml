<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="jpn_lang_dbm_desktop_app.BundleSelectorWindow"
        Width="520"
        Height="380"
        Title="Choose input"
        CanResize="True">
  <ListBox x:Name="BundleList"
           Margin="12"
           HorizontalAlignment="Stretch"
           VerticalAlignment="Stretch"
           DisplayMemberBinding="{ReflectionBinding SummaryText}"/>
</Window>
